# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/postgres"

# Authentication
# Generate a secure random string for this in production
JWT_SECRET="fallback_secret_key"

# CORS / Frontend connection
FRONTEND_URL="http://localhost:5173"

# Server environment
PORT=3001
NODE_ENV="development"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="your_blob_read_write_token_here"

# Frontend API Connection (Change this to your live Vercel URL when deploying the frontend)
VITE_API_URL="https://legal-portal-red.vercel.app"
